NODE_ENV=development
PORT=4000
# Local: mongodb://127.0.0.1:27017/ms-global
# Atlas: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ms-global?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb://127.0.0.1:27017/ms-global
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
# Public shop (customers) — published site only
PUBLIC_SITE_URL=http://localhost:5173
# Owner website editor — admin login only (separate deploy/port)
STUDIO_URL=http://localhost:5174
# Comma-separated CORS origins (defaults include FRONTEND + PUBLIC + STUDIO URLs)
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Optional: first admin (used by npm run seed:admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
